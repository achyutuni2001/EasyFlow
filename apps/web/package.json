{
  "name": "easyflow-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "sh ./scripts/dev-clean.sh",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma && prisma generate --schema prisma/tenant.schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma && prisma validate --schema prisma/tenant.schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:push:tenant": "prisma db push --schema prisma/tenant.schema.prisma",
    "seed:dataco": "npx tsx scripts/seed-dataco.ts",
    "seed:demo": "npx tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@langchain/core": "^1.1.48",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.2.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.15.0",
    "@xyflow/react": "^12.10.2",
    "better-auth": "^1.6.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "framer-motion": "^12.40.0",
    "langchain": "^1.4.4",
    "lucide-react": "^0.468.0",
    "next": "14.2.30",
    "prisma": "^6.15.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "^10.4.20",
    "csv-parse": "^6.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  }
}
