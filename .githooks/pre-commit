#!/usr/bin/env bash

set -euo pipefail

staged_files="$(git diff --cached --name-only)"

if [[ -z "${staged_files}" ]]; then
  exit 0
fi

while IFS= read -r staged_file; do
  [[ -z "${staged_file}" ]] && continue

  if [[ "${staged_file}" == ".env.example" || "${staged_file}" == */.env.example ]]; then
    continue
  fi

  if [[ "${staged_file}" == ".env" || "${staged_file}" == .env.* || "${staged_file}" == */.env || "${staged_file}" == */.env.* ]]; then
    echo "Blocked: staged files include env or key material."
    echo "Remove them from the commit before continuing."
    exit 1
  fi

  if [[ "${staged_file}" == *.pem || "${staged_file}" == *.key || "${staged_file}" == id_rsa || "${staged_file}" == id_ed25519 || "${staged_file}" == */id_rsa || "${staged_file}" == */id_ed25519 ]]; then
    echo "Blocked: staged files include env or key material."
    echo "Remove them from the commit before continuing."
    exit 1
  fi
done <<< "${staged_files}"

staged_diff="$(git diff --cached --text --unified=0)"

private_key_pattern='^\+.*BEGIN (RSA |OPENSSH |EC )?PRIVATE KEY'
credential_pattern='^\+.*(GOOGLE_CLIENT_SECRET|WEBHOOK_SECRET_KEY|BETTER_AUTH_SECRET|aws_secret_access_key)='
url_secret_pattern='^\+.*postgresql:\/\/[^ ]+:[^ ]+@'

if echo "${staged_diff}" | rg -i "${private_key_pattern}" >/dev/null; then
  echo "Blocked: staged diff looks like it contains secrets."
  echo "Review the staged changes and remove sensitive values."
  exit 1
fi

if echo "${staged_diff}" | rg -i "${credential_pattern}" | rg -v 'change-this|change-me|replace-with|^\+.*GOOGLE_CLIENT_SECRET=$' >/dev/null; then
  echo "Blocked: staged diff looks like it contains secrets."
  echo "Review the staged changes and remove sensitive values."
  exit 1
fi

if echo "${staged_diff}" | rg -i "${url_secret_pattern}" | rg -v 'USER:PASSWORD@HOST|easyflow:easyflow@postgres' >/dev/null; then
  echo "Blocked: staged diff looks like it contains secrets."
  echo "Review the staged changes and remove sensitive values."
  exit 1
fi

exit 0
