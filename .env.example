ENVIRONMENT=production
NEON_DATABASE_URL=postgresql+asyncpg://easyflow:easyflow@postgres:5432/easyflow
PRISMA_DATABASE_URL=postgresql://easyflow:easyflow@postgres:5432/easyflow
PRISMA_TENANT_DATABASE_URL=postgresql://easyflow:easyflow@postgres:5432/easyflow
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=easyflow.events
RABBITMQ_ROUTING_PREFIX=workflow
WEBHOOK_SECRET_KEY=change-this-webhook-secret
BETTER_AUTH_SECRET=change-this-auth-secret
APP_PUBLIC_URL=http://YOUR_SERVER_IP:3000
PUBLIC_API_URL=http://YOUR_SERVER_IP:8000
N8N_PUBLIC_URL=http://YOUR_SERVER_IP:5678/
N8N_HOST=YOUR_SERVER_IP
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_EMBEDDING_MODEL=nomic-embed-text
