# Gmail credentials (create an App Password at https://myaccount.google.com/apppasswords)
SENDER_EMAIL=your.email@gmail.com
SENDER_PASSWORD=your-16-char-app-password
RECIPIENT_EMAIL=your.email@gmail.com

# How often to check (hours)
CHECK_INTERVAL_HOURS=2

# Only show/alert jobs posted within this many hours
MAX_JOB_AGE_HOURS=24

# Notifications
ENABLE_EMAIL=true
ENABLE_DESKTOP_NOTIFY=true

# Location filters (comma-separated)
STATES=California,Texas,Washington
CITIES=Cupertino,Austin,Seattle
BUSINESS_CATEGORIES=amazon-web-services

# EasyFlow environment variables
ENVIRONMENT=development
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-example.neon.tech/easyflow?ssl=require
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=easyflow.events
RABBITMQ_ROUTING_PREFIX=workflow
